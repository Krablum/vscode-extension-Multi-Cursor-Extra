{
  "name": "multicursorex",
  "displayName": "multi-cursor++",
  "description": "",
  "version": "0.1.1",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:multicursorex.padding.pad",
    "onCommand:multicursorex.padding.originUp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
      "command": "multicursorex.padding.pad",
        "title": "Add padding"
      },
      {
        "command": "multicursorex.padding.originUp",
        "title": "originUp"
      },
      {
        "command": "multicursorex.padding.originDown",
        "title": "Change origin position to a lower height/increment origin position value"
      },
      {
        "command": "multicursorex.padding.originVisual",
        "title": "Indicate where is the origin currently at"
      }
    ],
    "keybindings":[
      {
        "command": "multicursorex.padding.originVisual",
        "key": "alt+click"
      
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.98.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "typescript": "^5.7.3",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  }
}
